begin
  ndims             1
  nvars             1
  size              80
  iproc             1
  ghost             3
  # Workload MUST match vanilla — patch overlay is reference-only, but the
  # bench report compares reference's elapsed against vanilla's; if they run
  # different iteration counts the comparison is invalid.  Vanilla's
  # solver.inp (tests/apps/vanillas/HyPar/.../solver.inp) sets n_iter=2500000
  # post-strip (commit 7fe28a068).  Keep this in sync when vanilla changes.
  n_iter            2500000
  time_scheme       rk
  time_scheme_type  ssprk3
  hyp_space_scheme  weno5
  par_space_type    nonconservative-1stage
  par_space_scheme  2
  dt                0.001
  screen_op_iter    1
  # --- Reference-mode addition: keep timestamped op_NNNNN.bin files as
  # native checkpoint artifacts.  binary format is restart-loadable;
  # op_overwrite=no preserves all files instead of overwriting one.
  file_op_iter      10000
  op_file_format    binary
  op_overwrite      no
  model             fp-double-well
end
