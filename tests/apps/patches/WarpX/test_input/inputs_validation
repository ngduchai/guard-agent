max_step = 50000
amr.n_cell = 384 384
amr.max_level = 0
geometry.dims = 2
geometry.prob_lo = -20.e-6 -20.e-6
geometry.prob_hi =  20.e-6  20.e-6
boundary.field_lo = periodic periodic
boundary.field_hi = periodic periodic

# --- Reference-mode addition: enable WarpX/AMReX checkpoint diagnostic.
# Cadence reset to 500 (was 10) — at max_step=50000 the original
# intervals=10 wrote 5000 chkpoint dirs × ~5MB each = ~28GB per run,
# filling the disk on any iteration that didn't successfully PRUNE
# (only successful runs prune; any failure left 28GB behind).
# 500 still gives 100 chkpoints across the run (kill at 50% step ~25000
# → latest chkpoint at step 25000 always exists for failure-injected
# recovery), and ~500MB total — disk-safe across many iterations.
diagnostics.diags_names = chkpoint
chkpoint.intervals = 500
chkpoint.diag_type = Full
chkpoint.format = checkpoint
