# Patched in.restart for SPARTA reference bench recovery (attempt_2+).
# Upstream in.restart (tests/apps/checkpointed/SPARTA/examples/free/in.restart)
# omits the `seed` command before read_restart, but SPARTA's read_restart
# code path checks RanMars (random_mars.cpp:91) before any RNG operation
# and aborts if no seed was set in this session.  The state stored in the
# restart file does NOT include the RNG; the user must always re-seed.
#
# Patch: add `seed 12345` at the top (matches in.validation:1).  Other
# directives unchanged from upstream.
seed            12345
read_restart    restart.sparta.*
# NOTE: NO `reset_timestep 0` here.  The upstream in.restart resets the
# step counter then runs 20000 more steps — that means attempt_2 always
# does a full 20000 steps regardless of how much attempt_1 already did.
# Combined with attempt_1's partial work, total physical steps exceed
# the original 20000-step target, BUT attempt_2 is much faster per-step
# (no `create_particles`/`create_grid` setup), so the wallclock comes
# out shorter than failure-free.  Removing reset_timestep + using
# `run 20000 upto` keeps the absolute target so attempt_2 only runs
# the REMAINING steps from the restart point.
stats           5000
compute         temp temp
stats_style     step cpu np nattempt ncoll c_temp
restart         2000 restart.sparta
timestep        7.00E-9
# IMPORTANT: must match the absolute step target in patches/SPARTA/.../
# in.validation (currently `run 165000`), NOT the upstream's 20000.
# `upto` makes attempt_2 only run REMAINING steps to reach 165000.
# If attempt_1 was killed at step 80000, attempt_2 runs 80000->165000.
run             165000 upto
