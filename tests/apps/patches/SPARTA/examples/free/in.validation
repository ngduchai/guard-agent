seed            12345
dimension       3
global          gridcut 1.0e-5 comm/sort yes
boundary        rr rr rr
create_box      0 0.0001 0 0.0001 0 0.0001
create_grid     20 20 20
balance_grid    rcb part
species         ar.species Ar
mixture         air Ar vstream 0.0 0.0 0.0 temp 273.15
global          nrho 7.07043E22
global          fnum 7.07043E6
create_particles air n 100000 twopass
stats           5000
compute         temp temp
stats_style     step cpu np nattempt ncoll c_temp
# --- Reference-mode addition: enable SPARTA native binary restart files
# (restart.sparta.NNNN).  Cadence 2000 steps lands well before the 5s
# injection delay (timestep=7e-9, 2000 steps ≈ 1-3s wall on 4 ranks).
restart         2000 restart.sparta
timestep        7.00E-9
run             165000
