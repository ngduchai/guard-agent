grid x=8 y=8 z=4 h=0.04
time t=15.0
testpointsource rho=1 cp=1.6 cs=0.8 halfspace=1
supergrid gp=30
source x=4.0 y=4.0 z=1.34 Mxx=1 Myy=1 Mzz=1 Mxy=0 Mxz=0 Myz=0 t0=0 freq=1 type=C6SmoothBump
developer checkfornan=0 cfl=1.3 reporttiming=1
# --- Reference-mode addition: enable SW4lite native restart files.
# Cadence 50 cycles fires well before the 6s injection delay
# (4 ranks advance ≥ 50 cycles per second on this small grid).
checkpoint cycleInterval=50 file=restart
