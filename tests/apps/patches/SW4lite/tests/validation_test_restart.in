# Recovery-attempt input for SW4lite reference bench (attempt_2+).
# Same physical setup as validation_test.in (which writes checkpoints
# every 50 cycles via `checkpoint cycleInterval=50 file=restart`),
# plus a `restart file=restart` directive that tells SW4lite to read
# the most-recent restart.cycle=NN.sw4checkpoint file at startup.
# Source: src/EW.C:850-888 (processRestart), CheckPoint.C:234-247
# (file naming).  No auto-detection — the explicit directive is required.
# IMPORTANT: time t=15.0 must match patches/SW4lite/tests/validation_test.in
# (the primary input attempt_1 uses), NOT the upstream's t=2.0.  The
# patched primary extended the workload from t=2.0 to t=15.0 so the
# benchmark has a meaningful runtime; the restart MUST use the same
# absolute target or attempt_2 immediately exits because the loaded
# state's time has already exceeded the smaller t.
grid x=8 y=8 z=4 h=0.04
time t=15.0
testpointsource rho=1 cp=1.6 cs=0.8 halfspace=1
supergrid gp=30
source x=4.0 y=4.0 z=1.34 Mxx=1 Myy=1 Mzz=1 Mxy=0 Mxz=0 Myz=0 t0=0 freq=1 type=C6SmoothBump
developer checkfornan=0 cfl=1.3 reporttiming=1
checkpoint cycleInterval=50 file=restart
# CheckPoint.C:411 opens mRestartFile.c_str() literally.  We use a
# symlink (`restart.recovery.sw4checkpoint` -> latest restart.cycle=NN
# file) created by patches/SW4lite/tests/_recovery_hook.sh at attempt_2
# launch.  This avoids hardcoding an early cycle (which previously made
# attempt_2 redo most of the simulation).
restart file=restart.recovery.sw4checkpoint
