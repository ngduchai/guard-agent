#!/bin/bash
# Per-rank checkpointed HPCG launcher.  Pins HPCG_FIXED_SETS so the auto-tuned
# numberOfCgSets matches across the kill-and-restart pair, sets the checkpoint
# cadence, then invokes xhpcg.  Rank 0 prints a VALIDATION marker to stdout.
set -u
: "${HPCG_FIXED_SETS:=180}"
: "${CKPT_EVERY:=10}"
export HPCG_FIXED_SETS CKPT_EVERY
script_dir="$(cd "$(dirname "$0")" && pwd)"
# Keep PWD as whatever the framework set so checkpoint state lives in the
# per-run dir (each run_N starts with no stale checkpoints; kill+restart
# attempts share the run dir and therefore see the checkpoints they wrote).
[ -f hpcg.dat ] || ln -sf "$script_dir/hpcg.dat" hpcg.dat 2>/dev/null
"$script_dir/xhpcg" "$@"
ec=$?
rank="${PMI_RANK:-${OMPI_COMM_WORLD_RANK:-${PMIX_RANK:-0}}}"
if [ "$rank" = "0" ]; then
  sleep 0.2
  report=$(ls -t HPCG-Benchmark_*.txt 2>/dev/null | head -1)
  if [ -n "$report" ] && grep -q "HPCG result is VALID" "$report"; then
    echo "HPCG_VALIDATION=PASSED"
  else
    echo "HPCG_VALIDATION=FAILED"
  fi
fi
exit "$ec"
