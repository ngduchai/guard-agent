# Nyx validation: Sod shock tube (hydro only, no gravity) with checkpointing
max_step = 200
stop_time = 0.2

nyx.h_species=.76
nyx.he_species=.24
nyx.small_temp = 1.e-4
nyx.small_dens = 1.e-6
nyx.gamma = 1.4
nyx.initial_z = 0.

# PROBLEM SIZE & GEOMETRY
geometry.is_periodic = 1 0 1
geometry.coord_sys   = 0
geometry.prob_lo     =  0      0     0
geometry.prob_hi     =  0.125  1.    0.125

amr.n_cell           = 4     32      4
amr.max_level        = 2

# BOUNDARY CONDITIONS
nyx.lo_bc       =  0   2   0
nyx.hi_bc       =  0   2   0

# PHYSICS
nyx.do_hydro = 1
nyx.do_grav  = 0

# COMOVING
nyx.comoving_OmM = 1.0e0
nyx.comoving_OmB = 0.0e0
nyx.comoving_h   = 0.0e0

nyx.ppm_type    = 0

# TIME STEP CONTROL
nyx.cfl            = 0.9
nyx.init_shrink    = 0.1
nyx.change_max     = 1.05
nyx.dt_cutoff      = 5.e-20

# DIAGNOSTICS
nyx.sum_interval   = 1
nyx.v              = 1
amr.v              = 1

# REFINEMENT
amr.ref_ratio       = 2 2 2 2
amr.regrid_int      = 2 2 2 2
amr.blocking_factor = 4 4 8
amr.max_grid_size   = 16 16 8
amr.n_error_buf     = 2 2 2 2
amr.refine_grid_layout = 1

# CHECKPOINTS (every 5 steps)
amr.check_file      = chk
amr.check_int       = 5

# PLOTFILES
amr.plot_file       = plt_
amr.plot_int        = -1

amr.probin_file = ""
prob.idir = 2
