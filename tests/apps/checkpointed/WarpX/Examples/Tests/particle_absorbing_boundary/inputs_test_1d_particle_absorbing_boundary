#################################
# Domain, Resolution & Numerics
#

# Disable `max_step` below to run until the physical `stop_time`.
max_step = 8000
#stop_time = 5.0e-12            # [s]

# small 1D case for CI, switch to run full 2d case similar to Miller et. al. 2021
amr.n_cell = 5120
#amr.n_cell = 128 8192

# simulation box, no MR
amr.max_level = 0

# switch for 2D case
geometry.dims = 1
geometry.prob_lo = -150e-6
geometry.prob_hi =  50.e-6
#geometry.dims = 2
#geometry.prob_lo = -1.6e-6 -774.156e-6
#geometry.prob_hi =  1.6e-6 150.e-6

# Boundary conditions (switch for 2D case)
boundary.field_lo = absorbing_silver_mueller
boundary.field_hi = absorbing_silver_mueller
boundary.particle_lo = absorbing
boundary.particle_hi = absorbing
#boundary.field_lo = periodic pml
#boundary.field_hi = periodic pml
#boundary.particle_lo = periodic absorbing
#boundary.particle_hi = periodic absorbing

# Order of particle shape factors
algo.particle_shape = 3

# numerical tuning
warpx.cfl = 0.999
warpx.use_filter = 1          # bilinear current/charge filter

# Grid size parameters (tune for performance on your machine)
amr.blocking_factor = 128
amr.max_grid_size = 1024
# 2D case:
#amr.max_grid_size_x = 128
#amr.max_grid_size_y = 2048  # this is confusingly named and means z in 2D

#################################
# Target Profile
#

#   definitions for plasma extent and density profile
my_constants.L    = 3e-6         # [m] scale length for exponential ramp-up
my_constants.zmin = -27e-6       # [m] lower bound of region with plasma
my_constants.nc   = 1.11634e27   # [m^-3]  critical density for 1 um laser
my_constants.n0   = 10.0         # [n_c]

particles.species_names = electrons hydrogen

# particle species
hydrogen.species_type = hydrogen
hydrogen.injection_style = NUniformPerCell
hydrogen.num_particles_per_cell_each_dim = 8
# 2d case:
#hydrogen.num_particles_per_cell_each_dim = 4 4
hydrogen.momentum_distribution_type = at_rest
hydrogen.zmin = zmin
hydrogen.profile = parse_density_function

electrons.species_type = electron
electrons.injection_style = NUniformPerCell
electrons.num_particles_per_cell_each_dim = 64
# 2D case:
#electrons.num_particles_per_cell_each_dim = 8 8
electrons.momentum_distribution_type = "maxwell_boltzmann"
electrons.theta = 0.0002  # corresponds to 0.1 keV temperature
electrons.zmin = zmin
electrons.profile = parse_density_function

# density profiles (target extent, pre-plasma and cutoffs defined above particle species list)
electrons.density_function(x,y,z) = "nc*n0*(
    if(z<=zmin, 0.0, 1.0 - exp(-(z - zmin)/L)))"
hydrogen.density_function(x,y,z) = "nc*n0*(
    if(z<=zmin, 0.0, 1.0 - exp(-(z - zmin)/L)))"

particle_thermalizer.normal = "z"
particle_thermalizer.start = 40e-6
particle_thermalizer.end = 50e-6
particle_thermalizer.momentum_threshold = 0.1
particle_thermalizer.theta = 0.02
# 2D case:
#particle_thermalizer.normal = "z"
#particle_thermalizer.start = 145e-6
#particle_thermalizer.end = 150e-6
#particle_thermalizer.momentum_threshold = 1.0
#particle_thermalizer.theta = 1.0
particle_thermalizer.species = electrons

# definitions used by laser profile
my_constants.Emax = 1e13
my_constants.omega0 = 1883651567308853.2 # [s^-1] angular frequency for lamba = 1.0e-6
my_constants.t_ramp0 = 0.13e-12
my_constants.t_ramp1 = 2.87e-12

#################################
# Laser Pulse Profile
#
lasers.names        = laser1
laser1.position     = 0. 0. -149.e-6    # point the laser plane (antenna)
# 2D case:
#laser1.position     = 0. 0. -773.156e-6 # point the laser plane (antenna)
laser1.direction    = 0. 0. 1.          # the plane's (antenna's) normal direction
laser1.polarization = 1. 0. 0.          # the main polarization vector
laser1.e_max        = Emax              # maximum amplitude of the laser field [V/m]
laser1.wavelength   = 1.0e-6            # central wavelength of the laser pulse [m]
laser1.profile      = parse_field_function
laser1.field_function(X,Y,t) = "Emax*cos(omega0*t)*(
    if (t < t_ramp0, t / t_ramp0, if (t > t_ramp1, 1.0 - ((t - t_ramp1)/t_ramp0), 1.0)))"

# #################################
# # Diagnostics
# #
diagnostics.diags_names = diagInst

# # instantaneous field and particle diagnostic
diagInst.intervals = 1000
diagInst.diag_type = Full

# #################################
# # Reduced Diagnostics
# #
warpx.reduced_diags_names                   = PhaseSpaceElectrons

PhaseSpaceElectrons.type                                 = ParticleHistogram2D
PhaseSpaceElectrons.intervals                            = 1000
PhaseSpaceElectrons.species                              = electrons
PhaseSpaceElectrons.bin_number_abs                       = 1000
PhaseSpaceElectrons.bin_number_ord                       = 1000
PhaseSpaceElectrons.bin_min_abs                          = -100.e-6
PhaseSpaceElectrons.bin_max_abs                          = 50.e-6
PhaseSpaceElectrons.bin_min_ord                          = -20
PhaseSpaceElectrons.bin_max_ord                          = 40
PhaseSpaceElectrons.histogram_function_abs(t,x,y,z,ux,uy,uz,w) = "z"
PhaseSpaceElectrons.histogram_function_ord(t,x,y,z,ux,uy,uz,w) = "uz"
PhaseSpaceElectrons.value_function(t,x,y,z,ux,uy,uz,w) = "w"
PhaseSpaceElectrons.openpmd_backend = h5

#################################
# Physical Background
#
# This example is modeled after the test case here:
#   [1] https://doi.org/10.1063/5.0065232
#
authors = "Andrew Myers <atmyers@lbl.gov>"
