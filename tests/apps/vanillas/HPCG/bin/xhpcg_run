#!/bin/bash
# Per-rank HPCG launcher for the validation framework.
# Each MPI rank invokes this script (the framework already wraps with mpirun);
# we just pass through to xhpcg.  Rank 0 also prints a stable VALIDATION marker
# to stdout after xhpcg exits so the framework's stdout-based comparison can
# match it (HPCG's official report goes to a per-run timestamped file).
set -u
script_dir="$(cd "$(dirname "$0")" && pwd)"
# Keep PWD as whatever the framework set (so per-run dirs isolate output);
# only fall back to script_dir if hpcg.dat isn't reachable, since xhpcg reads
# it from PWD.  Provide hpcg.dat in PWD via symlink.
[ -f hpcg.dat ] || ln -sf "$script_dir/hpcg.dat" hpcg.dat 2>/dev/null
"$script_dir/xhpcg" "$@"
ec=$?
rank="${PMI_RANK:-${OMPI_COMM_WORLD_RANK:-${PMIX_RANK:-0}}}"
if [ "$rank" = "0" ]; then
  # Give other ranks a moment in case of buffered file writes.
  sleep 0.2
  report=$(ls -t HPCG-Benchmark_*.txt 2>/dev/null | head -1)
  if [ -n "$report" ] && grep -q "HPCG result is VALID" "$report"; then
    echo "HPCG_VALIDATION=PASSED"
  else
    echo "HPCG_VALIDATION=FAILED"
  fi
fi
exit "$ec"
