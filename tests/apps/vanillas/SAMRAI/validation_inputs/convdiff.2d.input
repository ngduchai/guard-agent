AutoTester {
}

ConvDiff {
   convection_coeff  = 40.0, 20.0
   diffusion_coeff   = 0.1
   source_coeff      = 0.0
   cfl               = 0.5
   cell_tagging_tolerance = 20.0
   data_problem      = "SPHERE"
   Initial_data {
      radius            = 2.9
      center            = 5.5, 5.5
      val_inside     = 80.0
      val_outside    = 10.
   }
   Boundary_data {
      boundary_edge_xlo { boundary_condition = "FLOW" }
      boundary_edge_xhi { boundary_condition = "FLOW" }
      boundary_edge_ylo { boundary_condition = "FLOW" }
      boundary_edge_yhi { boundary_condition = "FLOW" }
      boundary_node_xlo_ylo { boundary_condition = "XFLOW" }
      boundary_node_xhi_ylo { boundary_condition = "XFLOW" }
      boundary_node_xlo_yhi { boundary_condition = "XFLOW" }
      boundary_node_xhi_yhi { boundary_condition = "XFLOW" }
   }
}
Main {
   dim = 2
   base_name = "convdiff_val"
   log_all_nodes = FALSE
   viz_dump_interval = 0
   restart_interval = 0
}
MainRestartData{
   max_timesteps = 5000
   start_time = 0.
   end_time = 100.
   regrid_step = 3
   tag_buffer = 2
}
CartesianGeometry{
   domain_boxes = [(0,0),(59,39)]
   x_lo = 0.e0, 0.e0
   x_up = 30.e0, 20.e0
}
PatchHierarchy {
   max_levels = 3
   ratio_to_coarser {
      level_1 = 4, 4
      level_2 = 4, 4
      level_3 = 4, 4
   }
   largest_patch_size {
      level_0 = 48, 48
   }
   smallest_patch_size {
      level_0 = 8, 8
   }
}
BergerRigoutsos {
   efficiency_tolerance = 0.70e0
   combine_efficiency = 0.85e0
}
GriddingAlgorithm{}
StandardTagAndInitialize { tagging_method = "GRADIENT_DETECTOR" }
MethodOfLinesIntegrator{}
LoadBalancer {}
