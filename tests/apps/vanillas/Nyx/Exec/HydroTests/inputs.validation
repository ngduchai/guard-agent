# Nyx validation: Sod shock tube (hydro only, no gravity)
# NOTE: vanilla wall is ~35s on this host -- below the 60s target from
# memory rule feedback_min_failure_free_runtime_60s.md.  Investigated
# 2026-05-18: neither max_step (4000) nor stop_time (4.0) is the binding
# constraint -- the Sod shock tube physics terminates naturally once
# the shock exits the domain.  The only way to lengthen Nyx is to grow
# the grid, but Nyx requires cubic cells (dx==dy==dz), so the only
# valid integer scale-up of n_cell=4 32 4 is to 8 64 8 (8x work,
# ~280s wall, too expensive for iter loops).  Accepting Nyx at 35s as
# a borderline case: v2.2's kill-fraction retry (f1=random in
# [0.50, 0.80], f2=max(0.50, f1-0.15), f3=0.50) gracefully handles the
# ~50% kill-window-collapse rate at f=0.80 for short apps by retrying
# at lower fractions where the window is wide enough (at f=0.50, the
# margin is 0.50*35 - 6 = 11.5s, safe).  Cost: ~1 extra mpirun per
# validation cycle when the f=0.80 attempt collapses.
max_step = 4000
stop_time = 4.0

nyx.h_species=.76
nyx.he_species=.24
nyx.small_temp = 1.e-4
nyx.small_dens = 1.e-6
nyx.gamma = 1.4
nyx.initial_z = 0.

# PROBLEM SIZE & GEOMETRY
geometry.is_periodic = 1 0 1
geometry.coord_sys   = 0
geometry.prob_lo     =  0      0     0
geometry.prob_hi     =  0.125  1.    0.125

amr.n_cell           = 4     32      4
amr.max_level        = 2

# BOUNDARY CONDITIONS
nyx.lo_bc       =  0   2   0
nyx.hi_bc       =  0   2   0

# PHYSICS
nyx.do_hydro = 1
nyx.do_grav  = 0

# COMOVING
nyx.comoving_OmM = 1.0e0
nyx.comoving_OmB = 0.0e0
nyx.comoving_h   = 0.0e0

nyx.ppm_type    = 0

# TIME STEP CONTROL
nyx.cfl            = 0.9
nyx.init_shrink    = 0.1
nyx.change_max     = 1.05
nyx.dt_cutoff      = 5.e-20

# DIAGNOSTICS
nyx.sum_interval   = 1
nyx.v              = 1
amr.v              = 1

# REFINEMENT
amr.ref_ratio       = 2 2 2 2
amr.regrid_int      = 2 2 2 2
amr.blocking_factor = 4 4 8
amr.max_grid_size   = 16 16 8
amr.n_error_buf     = 2 2 2 2
amr.refine_grid_layout = 1

# PLOTFILES
amr.plot_file       = plt_

amr.probin_file = ""
prob.idir = 2
