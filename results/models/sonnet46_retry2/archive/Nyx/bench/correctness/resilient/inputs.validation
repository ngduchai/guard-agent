# Nyx validation: Sod shock tube (hydro only, no gravity)
# 2026-05-24 v4: 8 48 8 failed AMReX abort "dx != dy != dz" -- prob_hi is
# (0.125, 1.0, 0.125), so n_cell ratio MUST be 1:8:1 (cubic-cell
# constraint).  Scaled to 8 64 8 (ratio 1:8:1, dx=dy=dz=0.015625).
# Blocking factor (4, 4, 8) still satisfied (8/4=2, 64/4=16, 8/8=1).
# v2 trial of 8 64 8 hardkilled at 150s; with v4 two-stage gate (build
# excluded from ceiling) the pure mpirun wall is what gates, and Sod
# shock domain-exit termination means grid-size is the only lever.
max_step = 4000
stop_time = 4.0

nyx.h_species=.76
nyx.he_species=.24
nyx.small_temp = 1.e-4
nyx.small_dens = 1.e-6
nyx.gamma = 1.4031
nyx.initial_z = 0.

# PROBLEM SIZE & GEOMETRY
geometry.is_periodic = 1 0 1
geometry.coord_sys   = 0
geometry.prob_lo     =  0      0     0
geometry.prob_hi     =  0.125  1.    0.125

amr.n_cell           = 8     64      8
amr.max_level        = 2

# BOUNDARY CONDITIONS
nyx.lo_bc       =  0   2   0
nyx.hi_bc       =  0   2   0

# PHYSICS
nyx.do_hydro = 1
nyx.do_grav  = 0

# COMOVING
nyx.comoving_OmM = 1.0e0
nyx.comoving_OmB = 0.0e0
nyx.comoving_h   = 0.0e0

nyx.ppm_type    = 0

# TIME STEP CONTROL
nyx.cfl            = 0.9
nyx.init_shrink    = 0.1
nyx.change_max     = 1.05
nyx.dt_cutoff      = 5.e-20

# DIAGNOSTICS
nyx.sum_interval   = 1
nyx.v              = 1
amr.v              = 1

# REFINEMENT
amr.ref_ratio       = 2 2 2 2
amr.regrid_int      = 2 2 2 2
amr.blocking_factor = 4 4 8
amr.max_grid_size   = 16 16 8
amr.n_error_buf     = 2 2 2 2
amr.refine_grid_layout = 1

# PLOTFILES
amr.plot_file       = plt_

amr.probin_file = ""
prob.idir = 2
