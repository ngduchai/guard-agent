# 2026-05-24 v5 root cause was NOT workload size: the v3/v4 mpirun
# hardkills at silent_for=241s were caused by an MPI deadlock in
# Source/main.cpp's validation-output emitter (MultiFab::sum is
# COLLECTIVE; was inside an IOProcessor()-only guard, so rank 0
# entered MPI_Allreduce alone while other ranks hit MPI_Finalize and
# blocked).  Deadlock latent until -np >= 2; surfaced at the 4-rank
# rebake.  Deadlock fix landed in main.cpp; with the fix the actual
# per-step cost at -np 4 is ~0.97ms (measured from v5 stdout STEP
# 1..200).  Restoring max_step to 80000 lands the run at ~80s evolve
# + ~5s init/finalize, comfortably mid-band [60,120].
# See memory feedback_min_failure_free_runtime_60s.md.
max_step = 80000
amr.n_cell = 384 384
amr.max_level = 0
geometry.dims = 2
geometry.prob_lo = -20.e-6 -20.e-6
geometry.prob_hi =  1.9502e-05  1.9502e-05
boundary.field_lo = periodic periodic
boundary.field_hi = periodic periodic

# 2026-05-19: added inhomogeneous initial E-field to make the simulation
# state non-trivial.  Without this, the input was pure vacuum and every cell's
# field value stayed at exactly 0.0 throughout the run, which let LLMs game the
# recovery test by bumping the step counter and skipping field state
# restoration entirely (the "recovered" output matched vanilla because both
# produced all-zero fields).  A Gaussian E_x pulse centered at the origin
# evolves via Maxwell's equations into a spreading wave that bounces off the
# periodic boundaries — distinct, evolving state at every step.  Recovery
# code that doesn't actually load the saved fields will produce a different
# final state than vanilla.
warpx.E_ext_grid_init_style = parse_E_ext_grid_function
warpx.Ex_external_grid_function(x,y,z) = "1.0e6 * exp(-((x*x + y*y) / (5.0e-6 * 5.0e-6)))"
warpx.Ey_external_grid_function(x,y,z) = "0.0"
warpx.Ez_external_grid_function(x,y,z) = "0.0"
