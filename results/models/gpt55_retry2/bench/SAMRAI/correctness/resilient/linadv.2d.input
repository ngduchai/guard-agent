AutoTester {
}

LinAdv {
   advection_velocity = 1.9593e+00 , 1.0e0

   godunov_order    = 4
   corner_transport = "CORNER_TRANSPORT_1"

   data_problem      = "SPHERE"
   Initial_data {
      radius            = 2.9
      center            = 5.5 , 5.5
      uval_inside       = 80.0
      uval_outside      = 5.
   }

   Refinement_data {
      refine_criteria = "UVAL_GRADIENT", "UVAL_SHOCK"
      UVAL_GRADIENT {
         grad_tol = 10.0
      }
      UVAL_SHOCK {
         shock_tol = 10.0
         shock_onset = 0.85
      }
   }

   Boundary_data {
      boundary_edge_xlo {
         boundary_condition      = "FLOW"
      }
      boundary_edge_xhi {
         boundary_condition      = "FLOW"
      }
      boundary_edge_ylo {
         boundary_condition      = "FLOW"
      }
      boundary_edge_yhi {
         boundary_condition      = "FLOW"
      }
      boundary_node_xlo_ylo {
         boundary_condition      = "XFLOW"
      }
      boundary_node_xhi_ylo {
         boundary_condition      = "XFLOW"
      }
      boundary_node_xlo_yhi {
         boundary_condition      = "XFLOW"
      }
      boundary_node_xhi_yhi {
         boundary_condition      = "XFLOW"
      }
   }
}

Main {
   dim = 2
   base_name = "linadv_val"
   log_all_nodes = FALSE
   viz_dump_interval = 0
}

TimerManager {
   print_exclusive = TRUE
}

CartesianGeometry{
   domain_boxes	= [(0,0),(599,419)]
   x_lo = 0.e0 , 0.e0
   x_up = 30.e0 , 20.e0
}

StandardTagAndInitialize {
   tagging_method = "GRADIENT_DETECTOR"
}

PatchHierarchy {
   max_levels = 3
   ratio_to_coarser {
      level_1 = 4 , 4
      level_2 = 4 , 4
      level_3 = 4 , 4
   }
   largest_patch_size {
      level_0 = 48, 48
   }
   smallest_patch_size {
      level_0 = 8, 8
   }
}

BergerRigoutsos {
   efficiency_tolerance    = 0.70e0
   combine_efficiency      = 0.85e0
}

GriddingAlgorithm{
}

HyperbolicLevelIntegrator{
   cfl                       = 0.9e0
   cfl_init                  = 0.9e0
   lag_dt_computation        = TRUE
   use_ghosts_to_compute_dt  = TRUE
}

TimeRefinementIntegrator{
   start_time           = 0.e0
   end_time             = 10.e0
   grow_dt              = 1.1e0
   max_integrator_steps = 300000
}

LoadBalancer {
}
