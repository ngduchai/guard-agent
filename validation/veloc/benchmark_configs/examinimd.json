      "name": "short-no-failure",
      "num_procs": 4,
      "app_args": [
        "-il",
        "${INPUT_DIR:-tests/ecp/vanillas/ExaMiniMD/input}/in.lj.short",
        "--comm-type",
        "MPI",
        "--kokkos-threads=1"
      ],
      "inject_failures": false,
      "num_runs": 3,
      "injection_delay": 10.0,
      "max_attempts": 1
