# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env
*.egg-info/
dist/
build/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

*api_key

# Claude Code working files
.claude/
plans/
MultiBlock/
plt*/

# Build-time-pulled meson/cmake subprojects (managed by app build systems, not us)
tests/apps/*/Nyx/subprojects/

# Per-run output logs that get regenerated on every iter
tests/apps/vanillas/SPPARKS/examples/*/log.spparks

# Backup files (any *.bak from editor / preflight saves)
*.bak

# C/C++ object files (upstream Makefiles drop these in-source on `make`)
*.o

# Compiled executables from manual upstream builds inside the reference tree
tests/apps/*/PRK_Stencil/Stencil/stencil

# Dropped / deactivated benchmark apps kept around as scratch (never tracked)
**/.miniVite_dropped/

# Validation/runtime byproducts produced by manual in-source app invocations
# (the canonical artifacts live under build/validation_output/ which is
# already covered by the build/ ignore above)
tests/apps/*/SAMRAI/linadv_val.log
tests/apps/*/SAMRAI/validation_output.bin
tests/apps/*/SAMRAI/restart_*/
