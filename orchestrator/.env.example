# LLM provider selection
# Supported values: openai | argo | generic
LLM_PROVIDER=argo

# Which model to use (check your provider's documentation for valid names)
LLM_MODEL=gpt-4o-mini

# ── OpenAI provider ──────────────────────────────────────────────────────────
# Set LLM_PROVIDER=openai and provide your OpenAI API key.
OPENAI_API_KEY=

# ── Argo provider (Argonne OpenAI-compatible proxy) ──────────────────────────
# Set LLM_PROVIDER=argo and provide the Argo API key.
# The base URL defaults to https://apps-dev.inside.anl.gov/argoapi/v1
ARGO_API_KEY=
# ARGO_BASE_URL=https://apps-dev.inside.anl.gov/argoapi/v1  # optional override

# ── Generic OpenAI-compatible provider ───────────────────────────────────────
# Set LLM_PROVIDER=generic to use any OpenAI-compatible API endpoint.
# Examples: vLLM, LiteLLM, a custom gateway, or any provider that exposes
# the OpenAI chat-completions API.
#
# from openai import OpenAI
# client = OpenAI(api_key=LLM_API_KEY, base_url=LLM_BASE_URL)
# response = client.chat.completions.create(model=LLM_MODEL, messages=...)
#
LLM_BASE_URL=https://my-llm-gateway.example.com/v1
LLM_API_KEY=

# ── Anthropic provider (orchestrator only, not veloc agent) ──────────────────
ANTHROPIC_API_KEY=

# Optional
ENVIRONMENT_TYPE=hpc
